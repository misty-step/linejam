# Convex
# Fill from the Convex deployment you want local Dagger and Playwright to target.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Convex Deploy Key (optional mirror for hosted CI - never commit real values)
CONVEX_DEPLOY_KEY=
# Local/shared development must declare development. Set to production on the
# DigitalOcean web component so a missing or mismatched marker fails closed.
LINEJAM_DEPLOY_ENVIRONMENT=development

# Rolling-deploy skew protection. App Platform production binds
# NEXT_DEPLOYMENT_ID to ${_self.COMMIT_HASH}; local builds may leave it blank.
# Keep the 32-byte base64 Server Action key stable across production builds.
# Generate once with: openssl rand -base64 32
NEXT_DEPLOYMENT_ID=
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional override for Convex Clerk auth. When omitted, the issuer is derived
# from NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY.
CLERK_JWT_ISSUER_DOMAIN=

# Guest token signing/verification
# CRITICAL: This secret MUST be identical in:
#   1. DigitalOcean App Platform env vars (for Next.js signing)
#   2. Convex env vars (for backend verification)
#   3. Any hosted CI mirror you keep alongside local Dagger runs
# Generate with: openssl rand -base64 32
GUEST_TOKEN_SECRET=

# OpenRouter API (for AI players - Convex only)
# Get from https://openrouter.ai/keys
# Note: Set this in Convex environment vars, not App Platform
OPENROUTER_API_KEY=

# Canary ingestion
# Use private server credentials where possible; browser bundles use the
# write-only NEXT_PUBLIC key for client-side boundaries and automatic capture.
# Replace the example public key with a real write key before running the
# authoritative local Dagger contract or any deployed build.
CANARY_ENDPOINT=https://canary.mistystep.io
CANARY_API_KEY=example_canary_server_key
NEXT_PUBLIC_CANARY_ENDPOINT=https://canary.mistystep.io
NEXT_PUBLIC_CANARY_API_KEY=example_canary_write_key
CANARY_ENVIRONMENT=production

# Canary responder + smoke loop
LINEJAM_CANARY_SERVICE=linejam
LINEJAM_CANARY_WEBHOOK_URL=
LINEJAM_CANARY_WEBHOOK_SECRET=
CANARY_WEBHOOK_SEND_TEST=0
LINEJAM_CANARY_RESPONDER_PORT=8787
LINEJAM_CANARY_WEBHOOK_PATH=/canary/webhook
LINEJAM_CANARY_STORE_DIR=.canary
LINEJAM_CANARY_MAX_BODY_BYTES=262144
CANARY_SMOKE_TRIGGER_ENABLED=1
CANARY_SMOKE_MAX_IN_FLIGHT=2
CANARY_SMOKE_MAX_PENDING=20
CANARY_SMOKE_TIMEOUT_MS=600000
LINEJAM_SMOKE_RUNNER=dagger
PLAYWRIGHT_BASE_URL=https://www.linejam.app
# Optional: enables authenticated remote smoke by signing a dedicated Clerk
# test user in via testing tokens. Requires CLERK_SECRET_KEY as well. When
# omitted, Playwright provisions and signs in a default
# `linejam-e2e+clerk_test@example.com` user automatically.
PLAYWRIGHT_CLERK_TEST_EMAIL=
# Dagger E2E treats authenticated browser coverage as part of the default
# contract. Set to 0 only when you are intentionally running a guest-only loop.
PLAYWRIGHT_REQUIRE_AUTH_E2E=1
# Local Dagger syncs the active Convex dev deployment automatically before
# auth-heavy E2E runs. Set to 0 only when you intentionally want to skip that.
LINEJAM_SYNC_CONVEX_BEFORE_DAGGER=1
# Local Dagger can bootstrap the Clerk "convex" JWT template automatically for
# dev/test keys. Keep this at 0 for live keys unless you intentionally want the
# CLI to create the template in a real Clerk instance.
LINEJAM_ALLOW_LIVE_CLERK_TEMPLATE_CREATE=0
# Local Dagger refuses to push Convex production code unless you opt in.
LINEJAM_ALLOW_PROD_CONVEX_SYNC=0
# Set to 1 when smoke must fail instead of skipping the authenticated path.
PLAYWRIGHT_REQUIRE_AUTH_SMOKE=1
# Optional hosted-smoke guardrail. When enabled, smoke refuses untrusted base
# URLs unless they match one of the configured allowlist knobs below.
LINEJAM_ENFORCE_SMOKE_URL_ALLOWLIST=0
LINEJAM_ALLOWED_SMOKE_ORIGINS=
LINEJAM_ALLOWED_SMOKE_HOSTS=
LINEJAM_ALLOWED_SMOKE_HOST_PATTERN=
# Bound Canary context fetches from the responder and prune stale artifacts.
LINEJAM_CANARY_CONTEXT_TIMEOUT_MS=5000
LINEJAM_CANARY_RETENTION_DAYS=14
LINEJAM_CANARY_PRUNE_INTERVAL_MS=3600000

# PostHog Product Analytics
# Get from PostHog project settings
NEXT_PUBLIC_POSTHOG_KEY=
# Uses /ingest reverse proxy by default (see next.config.ts rewrites)
# Override with NEXT_PUBLIC_POSTHOG_HOST if needed
NEXT_PUBLIC_POSTHOG_HOST=

# Set by the deployment pipeline when release correlation is required.
# GITHUB_SHA is the canonical hosted-CI source revision.
